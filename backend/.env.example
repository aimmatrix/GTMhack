# ──────────────────────────────────────────────────────────────────────────
# Lightfern Reach backend — environment configuration
# Copy to `.env` and fill in. EVERYTHING has a mock fallback, so the server
# runs end-to-end even with this file empty. Add keys to flip modules to live.
# ──────────────────────────────────────────────────────────────────────────

# --- Server ---
PORT=8787
# Comma-separated list of allowed origins for the static frontend.
# Use * for hackathon convenience.
CORS_ORIGIN=*
LOG_LEVEL=info

# --- Search: Explorium B2B / Unify prospecting API ---
# Partner API key (Explorium api_key header). Unify CRM keys (u_…) may not
# include B2B search — if so the provider falls back to mock fixtures.
# Base URL for prospect search: https://api.explorium.ai/v1
# (The Unify CRM Data API at api.unifygtm.com/data/v1 is auto-redirected.)
UNIFY_API_KEY=
UNIFY_API_BASE_URL=https://api.explorium.ai/v1
# Force a provider regardless of keys: "unify" | "mock" | "auto"
SEARCH_PROVIDER=auto

# --- LLM: Google Gemini ---
# When GEMINI_API_KEY is set, briefs + research notes are generated by Gemini.
# When empty, deterministic templated notes are used.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Force a provider regardless of keys: "gemini" | "mock" | "auto"
LLM_PROVIDER=auto

# --- Handoff: Gmail draft (Lightfern Chrome extension takes over in Gmail) ---
# If Gmail OAuth is configured, /api/lightfern/handoff creates a real Gmail draft.
# If not, it returns a Gmail compose deep-link (no auth) that prefills the email.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# The Gmail account drafts are created in / sent from (e.g. you@company.com)
GMAIL_SENDER=
# Force a mode: "gmail_api" | "compose_link" | "auto"
HANDOFF_MODE=auto

# Optional: recipient for scripts/verify-gmail-draft.ts
# GMAIL_VERIFY_TO=someone@example.com

# --- Run behaviour ---
# Max number of match cards per run (PRD suggests 5-10 high-quality matches).
MAX_RESULTS=8

# --- Optional persistence (Supabase) ---
# When both are set, runs are persisted to the `runs` table (see supabase/migrations/).
SUPABASE_URL=
SUPABASE_KEY=
