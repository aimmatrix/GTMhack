{
  "name": "lightfern-reach-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for Lightfern Reach / Noodle — natural-language target → Unify search → research packets → Gmail draft handoff for Lightfern.",
  "license": "MIT",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gmail:oauth": "tsx scripts/gmail-oauth.ts",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@supabase/supabase-js": "^2.47.10",
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "googleapis": "^144.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
